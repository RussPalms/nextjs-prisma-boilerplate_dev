
APP_ENV=replit

# ------------------
# replit

# http - use http server
SITE_PROTOCOL=http

# only backend will use this port (http server)
PORT=42069

SITE_HOSTNAME=nextjs-prisma-boilerplate-node16_dev.russpalms.repl.co

# no port in url
#NEXTAUTH_URL=https://nextjs-prisma-boilerplate-node16_dev.russpalms.repl.co
NEXTAUTH_URL=https://${SITE_HOSTNAME}

# https://replit.com/russpalms/nextjs-prisma-boilerplate-node16_dev#package.json

# -----------------
# examples

#https://nextjs-prisma-boilerplate-node16_dev.russpalms.repl.co

# workspace
#https://replit.com/russpalms/nextjs-prisma-boilerplate-node16_dev

SITE_HOSTNAME=${PORT}-${HOSTNAME}.${GITPOD_WORKSPACE_CLUSTER_HOST}


# no port in url
#NEXTAUTH_URL=https://42069-russpalms-nextjsprismabo-h4e9fmpo6a5.ws-eu47.gitpod.io
NEXTAUTH_URL=https://${PORT}-${HOSTNAME}.${GITPOD_WORKSPACE_CLUSTER_HOST}


